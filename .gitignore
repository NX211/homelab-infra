# Helm
*.tgz
charts/
Chart.lock

# Allow staging app subchart dependencies (required for ArgoCD)
!staging-apps/*/charts/
!staging-apps/*/charts/*.tgz
!staging-apps/*/Chart.lock

# Secrets (never commit!)
*.secret.yaml
*-secret.yaml
# Ignore everything inside any 'secrets' directory at any depth, EXCEPT
# inventory manifests (*.json) in the repo-root secrets/. Manifests contain
# only UUID→name mappings (no values). Mirrors platform-infra/secrets/.
**/secrets/**
!/secrets/*.json

# Backups
*.backup
*.bak

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Temp files
*.tmp
tmp/
